{
  "name": "language-planet",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server:dev": "tsx server/search-server.ts",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "electron:dev": "vite build && node scripts/bundle-electron.mjs",
    "electron:build": "npm run build && node scripts/bundle-electron.mjs && electron-builder --win --dir",
    "electron:dist": "npm run build && node scripts/bundle-electron.mjs && electron-builder --win",
    "electron:portable": "npm run build && node scripts/bundle-electron.mjs && electron-builder --win portable",
    "electron:compile": "node scripts/bundle-electron.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "framer-motion": "^11.1.7",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.1",
    "esbuild": "^0.21.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.22.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  },
  "build": {
    "appId": "com.languageplanet.filesearch",
    "productName": "文件搜索工具",
    "directories": {
      "output": "output-hashrouter"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-Portable.exe"
    },
    "asar": false
  }
}
